# Dawarich self-hosted location store (copy to docker/dawarich.env or set in root .env)
# See https://dawarich.app/docs/self-hosting/environment-variables/

DAWARICH_APP_PORT=3000
RAILS_ENV=production
SECRET_KEY_BASE=change-me-to-a-long-random-string
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=dawarich_development
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=dawarich_development
TIME_ZONE=Asia/Jerusalem
APPLICATION_HOSTS=localhost,127.0.0.1,::1
STORE_GEODATA=true
SELF_HOSTED=true

# Optional reverse geocoding (Photon container)
# PHOTON_API_HOST=http://photon:2322
